{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "public" } 
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/functions/signal_function/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/$1"
    }
  ]
}
