{
  "version": 2,
  "builds": [
    {
      "src": "functions/signal_function/main.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard/package.json",
      "use": "@vercel/next",
      "config": { "workPath": "dashboard" }
    }
  ],
  "routes": [
    {
      "src": "/api/signal",
      "dest": "/functions/signal_function/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/$1"
    }
  ]
}