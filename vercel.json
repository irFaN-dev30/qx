{
  "version": 2,
  "builds": [
    {
      "src": "api/signal.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard/package.json",
      "use": "@vercel/next",
      "config": { "workPath": "dashboard" }
    }
  ],
  "routes": [
    {
      "src": "/api/signal",
      "dest": "/api/signal.py"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "^/(.*)$",
      "dest": "/dashboard/$1"
    }
  ]
}
