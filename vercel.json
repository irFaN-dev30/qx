{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/api/index",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard"
    }
  ]
}