{
  "version": 2,
  "builds": [
    {
      "src": "functions/signal_function/main.py",
      "use": "@vercel/python",
      "config": {
        "pip": "install -r functions/signal_function/requirements.txt",
        "playwright": "install-deps"
      }
    },
    {
      "src": "dashboard/package.json",
      "use": "@vercel/next",
      "config": { "workPath": "dashboard" }
    }
  ],
  "routes": [
    {
      "src": "/api/signal",
      "dest": "/functions/signal_function/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/$1"
    }
  ]
}