{
  "version": 2,
  "builds": [
    {
      "src": "dashboard/next.config.mjs",
      "use": "@vercel/next",
      "config": { "workPath": "dashboard" }
    },
    {
      "src": "functions/signal_function/main.py",
      "use": "@vercel/python",
      "config": {
        "build": "bash functions/signal_function/build_python.sh",
        "maxLambdaSize": "150mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/functions/signal_function/main.py"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/$1"
    }
  ]
}
