{
  "version": 2,
  "builds": [
    {
      "src": "api/signal.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": "API-Quotex-main/**",
        "maxLambdaSize": "50mb"
      }
    },
    {
      "src": "dashboard/package.json",
      "use": "@vercel/next",
      "config": { "workPath": "dashboard" }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/signal.py"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/$1"
    }
  ]
}
