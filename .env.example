# Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# ============================================
# Quotex Credentials (REQUIRED)
# ============================================
QUOTEX_EMAIL=your_email@example.com
QUOTEX_PASSWORD=your_password_here

# ============================================
# Trading Configuration (OPTIONAL)
# ============================================
# Comma-separated list of currency pairs to monitor
SIGNAL_ASSETS=EURUSD,GBPUSD,USDJPY,AUDUSD

# Timeframe in seconds for candle analysis
SIGNAL_TIMEFRAME=60

# Number of candles to fetch for analysis
SIGNAL_CANDLE_COUNT=100

# RSI period for calculation
SIGNAL_RSI_PERIOD=14

# Bollinger Bands period
SIGNAL_BB_PERIOD=20

# Bollinger Bands standard deviation
SIGNAL_BB_STD_DEV=2

# EMA periods
SIGNAL_EMA_FAST=5
SIGNAL_EMA_SLOW=20

# ============================================
# API Configuration (OPTIONAL)
# ============================================
# Port for local Flask development
API_PORT=5000

# Flask debug mode (set to False in production)
FLASK_DEBUG=False

# ============================================
# Frontend Configuration (OPTIONAL)
# ============================================
# API URL for frontend (used in Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3000/api/signal

# ============================================
# Logging Configuration (OPTIONAL)
# ============================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory
LOG_DIR=./logs

# ============================================
# Note: Keep this file secure!
# Never commit .env to version control.
# Use .env.local for local development.
# ============================================
